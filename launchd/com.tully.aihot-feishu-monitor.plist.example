<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tully.aihot-feishu-monitor</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>-u</string>
    <string>/Users/tully/01work/aihot-feishu-monitor/aihot_feishu_monitor.py</string>
    <string>--env-file</string>
    <string>/Users/tully/01work/aihot-feishu-monitor/.env</string>
    <string>--loop</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/tully/01work/aihot-feishu-monitor</string>

  <key>StandardOutPath</key>
  <string>/Users/tully/.aihot-feishu-monitor/monitor.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/tully/.aihot-feishu-monitor/monitor.err.log</string>
</dict>
</plist>
