# AI HOT public API needs an identifiable non-browser User-Agent.
# Replace the contact part with your team or email if you deploy it long-term.
AIHOT_USER_AGENT=aihot-feishu-monitor/0.1 (+local)

# selected = AI HOT 精选; all = 全部 AI 动态
AIHOT_MODE=selected

# Optional: ai-models | ai-products | industry | paper | tip
# AIHOT_CATEGORY=

# AI HOT recommends polling fingerprint at >= 60 seconds.
AIHOT_POLL_INTERVAL_SECONDS=60
AIHOT_TAKE=50
MAX_NOTIFY_PER_CYCLE=8
AIHOT_STATE_FILE=~/.aihot-feishu-monitor/state.json

# Required for real Feishu delivery unless FEISHU_WEBHOOK_FILE exists.
FEISHU_WEBHOOK_URL=

# Optional fallback file. Defaults to ~/.claude/.feishu-webhook.
# FEISHU_WEBHOOK_FILE=/Users/tully/.claude/.feishu-webhook

# Required only if the Feishu custom bot has signing enabled.
FEISHU_WEBHOOK_SECRET=
